{
  "name": "smart-waste-backend",
  "version": "1.0.0",
  "description": "Backend API for Smart Waste Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx nodemon -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "check-duplicates": "jscpd src --config .jscpdrc.json",
    "check-duplicates:strict": "jscpd src --config .jscpdrc.json --threshold 0",
    "train:ml": "ts-node -r tsconfig-paths/register src/scripts/trainMLModel.ts",
    "import:synthetic": "ts-node -r tsconfig-paths/register src/scripts/importSyntheticData.ts",
    "trigger:predictions": "ts-node -r tsconfig-paths/register src/scripts/triggerPredictions.ts",
    "test:ml": "ts-node -r tsconfig-paths/register src/scripts/testMLFunctions.ts",
    "test:create-bin": "ts-node -r tsconfig-paths/register src/scripts/testCreateBin.ts",
    "create:500bins": "ts-node -r tsconfig-paths/register src/scripts/create500BinsAndTest.ts",
    "generate:accuracy": "ts-node -r tsconfig-paths/register src/scripts/generatePredictionAccuracy.ts",
    "generate:historical": "ts-node -r tsconfig-paths/register src/scripts/generateHistoricalDataForAccuracy.ts",
    "fix:bin-locations": "ts-node -r tsconfig-paths/register src/scripts/fixBinLocations.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "aws-iot-device-sdk-v2": "^1.15.12",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "mqtt": "^5.3.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@jscpd/html-reporter": "^4.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "jscpd": "^4.0.5",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
