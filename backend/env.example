# Smart Waste Management System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB Atlas Connection String
# Get this from MongoDB Atlas → Connect → Connect your application
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# IMPORTANT: Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Port for the backend API server
API_PORT=3000

# Environment (development, production, test)
NODE_ENV=development

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Secret key for JWT tokens (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production

# JWT token expiration time
JWT_EXPIRES_IN=24h

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ===========================================
# REDIS CONFIGURATION (Optional)
# ===========================================
# Redis URL for caching (optional for development)
REDIS_URL=redis://localhost:6379

# ===========================================
# MQTT CONFIGURATION (Optional)
# ===========================================
# MQTT broker URL for IoT devices
MQTT_BROKER_URL=mqtt://localhost:1883

# MQTT client ID
MQTT_CLIENT_ID=smart-waste-backend

# MQTT credentials (if required)
MQTT_USERNAME=
MQTT_PASSWORD=

# ===========================================
# ML SERVICE CONFIGURATION
# ===========================================
# URL of the ML microservice (runs on port 8888 to avoid Windows port restrictions)
ML_SERVICE_URL=http://localhost:8888

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
# SMTP settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_PATH=./uploads

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable metrics collection
ENABLE_METRICS=false

# ===========================================
# MOBILE APP CONFIGURATION (Optional)
# ===========================================
# Firebase Cloud Messaging for push notifications
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# ===========================================
# AWS IOT CONFIGURATION (Optional)
# ===========================================
# AWS IoT Core settings for IoT devices
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.region.amazonaws.com
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# ===========================================
# DEVELOPMENT NOTES
# ===========================================
# 1. Never commit the .env file to version control
# 2. Use strong passwords and secrets in production
# 3. Rotate secrets regularly
# 4. Use environment-specific configurations
# 5. Test your configuration with: node test-database-connection.js







































