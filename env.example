# Database Configuration
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority

REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# AWS IoT Core Configuration
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.region.amazonaws.com
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# MQTT Configuration
MQTT_BROKER_URL=mqtts://your-iot-endpoint.iot.region.amazonaws.com:8883
MQTT_CLIENT_ID=smart-waste-backend
MQTT_TOPIC_PREFIX=smartwaste

# API Configuration
API_PORT=3000
ML_SERVICE_URL=http://localhost:8888
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Monitoring
LOG_LEVEL=info
ENABLE_METRICS=true

# Mobile App Configuration
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# Development
NODE_ENV=development
DEBUG=smartwaste:*

